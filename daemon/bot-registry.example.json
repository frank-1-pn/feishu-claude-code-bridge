{
  "_doc": "Bot registry. (1) 'bots' = per-bot config used by daemon scripts and write-binding.ps1. (2) 'default' = AutoBot fallback for notify-once.ps1 when no binding file matches and no project matches. (3) 'projects' = AutoBot routing by CLAUDE_PROJECT_DIR substring (used when binding file missing).",
  "bots": {
    "bot1": {
      "chat_id": "<CHAT_ID_BOT_PRIMARY>",
      "profile": "",
      "alias": "Bot1 (笔记助手)"
    },
    "coding": {
      "chat_id": "<CHAT_ID_CODING_ASSISTANT>",
      "profile": "coding-assistant-claude",
      "alias": "编程助手_claude"
    },
    "finance": {
      "chat_id": "<CHAT_ID_FINANCE_AGENT>",
      "profile": "finance-agent",
      "alias": "finance-agent"
    }
  },
  "default": {
    "chat_id": "<CHAT_ID_BOT_PRIMARY>",
    "profile": "",
    "alias": "Bot1 (笔记助手)"
  },
  "projects": [
    {
      "match_dir_contains": "finance-agent-spec",
      "chat_id": "<CHAT_ID_FINANCE_AGENT>",
      "profile": "finance-agent",
      "alias": "finance-agent"
    }
  ]
}
